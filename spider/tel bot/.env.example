# ── Telegram Bot ───────────────────────────────────────────────
# Token from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs that get the admin panel
ADMIN_TELEGRAM_IDS=123456789,987654321

# SQLite DB file (absolute or relative to bot dir)
DB_PATH=bot.db

# ── Spider Panel integration (REST) ────────────────────────────
# Either a single server:
SPIDER_API_BASE=https://panel1.example.com
SPIDER_API_TOKEN=your-spider-security-token

# Or multiple instances for load-balancing / operator routing.
# Each entry: name, base_url, token, operators (MTN/MCI/Irancell/Hamrah/Rightel).
# When SPIDER_SERVERS is set it takes precedence over the single-server vars.
SPIDER_SERVERS=[{"name":"ir-mtn-1","base_url":"https://mtn1.example.com","token":"tok1","operators":["MTN"]},{"name":"ir-mci-1","base_url":"https://mci1.example.com","token":"tok2","operators":["MCI"]},{"name":"ir-irancell-1","base_url":"https://irancell1.example.com","token":"tok3","operators":["Irancell"]}]

# Request timeout (seconds) for Spider REST calls
SPIDER_TIMEOUT=15

# ── Shop ───────────────────────────────────────────────────────
CURRENCY=تومان

# Plan catalogue: plan_id -> {gb, days, price}
PLANS={"1":{"gb":5,"days":30,"price":50000},"2":{"gb":15,"days":30,"price":120000},"3":{"gb":50,"days":30,"price":300000}}

# ── Dev / Mock ─────────────────────────────────────────────────
# Set true to run without a live Spider backend (returns canned data)
MOCK_MODE=false

# ── Webhook (optional; leave empty for long-polling) ───────────
WEBHOOK_URL=
PORT=8443
